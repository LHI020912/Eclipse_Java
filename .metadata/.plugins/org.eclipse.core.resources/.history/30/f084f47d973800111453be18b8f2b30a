package test;

public class SongProject {
    public static void main(String[] args) {
        System.out.println("🎵 ENHYPEN - No Doubt 실행 중...\n");

        // 가사 데이터: {가사 내용, 글자당 속도(ms), 줄 바꿈 후 대기 시간(ms)}
        displayLine("Girl where you at?", 80, 800);
        displayLine("해가 떠서 질 때까지 난 계속 불안해", 80, 1000);
        displayLine("By the end of the day 미치겠어 Miss you", 80, 1200);
        
        System.out.println("\n(Chorus)");
        displayLine("Ain't no doubt 넌 나의 답", 70, 800);
        displayLine("No worries 난 괜찮아", 70, 800);
        displayLine("널 원해 괴롭지만", 70, 800);
        displayLine("Oh 날 태워 증명해 Baby no doubt", 70, 1500);

        System.out.println("\n(Bridge)");
        displayLine("Yeah no doubt", 100, 500);
        displayLine("Yeah baby no doubt", 100, 500);
        displayLine("Yeah no doubt", 100, 500);
    }

    public static void displayLine(String line, int charSpeed, int lineDelay) {
        for (char c : line.toCharArray()) {
            System.out.print(c);
            System.out.flush(); 
            try {
                Thread.sleep(charSpeed); 
            } catch (InterruptedException e) {
                Thread.currentThread().interrupt();
            }
        }
        System.out.println(); 
        try {
            Thread.sleep(lineDelay); 
        } catch (InterruptedException e) {
            Thread.currentThread().interrupt();
        }
    }
}