package test;

import java.io.BufferedReader;
import java.io.FileReader;

public class AutoLyricsPlayer {
    // 색상 코드
    public static final String RESET = "\u001B[0m";
    public static final String PURPLE = "\u001B[35m";
    public static final String CYAN = "\u001B[36m";

    public static void main(String[] args) {
    	String filePath = "src/test/nodoubt.lrc";
        
        long startTime = System.currentTimeMillis();
        boolean isFirstLine = true;

        try (BufferedReader br = new BufferedReader(new FileReader(filePath))) {
            String fileLine;
            while ((fileLine = br.readLine()) != null) {
                
                if (fileLine.startsWith("[")) {
                    // 1. 시간 및 가사 추출
                    int min = Integer.parseInt(fileLine.substring(1, 3));
                    int closeBracketIndex = fileLine.indexOf("]");
                    double sec = Double.parseDouble(fileLine.substring(4, closeBracketIndex));
                    
                    long targetTime = (long) ((min * 60 + sec) * 1000);
                    
                    // 2. 가사 추출: ] 다음(index + 1)부터 끝까지 자릅니다.
                    String content = fileLine.substring(closeBracketIndex + 1);

                    // 2. 노래 박자에 맞춰 대기
                    while (System.currentTimeMillis() - startTime < targetTime) {
                        Thread.sleep(10);
                    }

                    if (isFirstLine) {
                        System.out.print(CYAN); 
                    }
                    
                    // 3. 한 글자씩 타이핑 출력
                    for (char c : content.toCharArray()) {
                        System.out.print(c + RESET);
                        System.out.flush();
                        Thread.sleep(80); // 타이핑 속도
                    }
                    System.out.println();
                }
            }
            System.out.println("\n" + PURPLE + "✨ 노래가 종료되었습니다." + RESET);
            
        } catch (Exception e) {
            System.out.println("에러 발생: " + e.getMessage());
            e.printStackTrace();
        }
    }
}