package test;

import java.io.BufferedReader;
import java.io.FileReader;

public class AutoLyricsPlayer {
	
	public class ColorLyrics {
	    // ANSI 색상 코드 정의
	    public static final String RESET = "\u001B[0m";     // 색상 초기화
	    public static final String RED = "\u001B[31m";      // 빨강 (강렬한 느낌)
	    public static final String GREEN = "\u001B[32m";    // 초록
	    public static final String YELLOW = "\u001B[33m";   // 노랑
	    public static final String PURPLE = "\u001B[35m";   // 보라 (신비로운 느낌)
	    public static final String CYAN = "\u001B[36m";
	    
    public static void main(String[] args) {
        String filePath = "nodoubt.lrc"; // 위에서 만든 파일 이름
        long startTime = System.currentTimeMillis();

        try (BufferedReader br = new BufferedReader(new FileReader(filePath))) {
            String line;
            while ((line = br.readLine()) != null) {
                // [00:12.34] 가사내용 추출
                if (line.startsWith("[")) {
                    int min = Integer.parseInt(line.substring(1, 3));
                    double sec = Double.parseDouble(line.substring(4, 9));
                    long targetTime = (long) ((min * 60 + sec) * 1000); // 목표 밀리초
                    String content = line.substring(10);

                    // 목표 시간까지 대기
                    while (System.currentTimeMillis() - startTime < targetTime) {
                        Thread.sleep(10); 
                    }

                    // 한 글자씩 타이핑 출력
                    for (char c : content.toCharArray()) {
                        System.out.print(c);
                        System.out.flush();
                        Thread.sleep(50); // 글자 속도
                    }
                    System.out.println();
                }
            }
        } catch (Exception e) {
            e.printStackTrace();
        }
    }
}
}